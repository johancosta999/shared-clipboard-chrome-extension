{
  "manifest_version": 3,
  "name": "Shared Clipboard",
  "version": "1.0",
  "description": "A real-time shared clipboard extension using WebSockets.",
  "action": {},
  "background": {
    "service_worker": "service-worker.js",
    "type": "module"
  },
  "permissions": [
    "clipboardRead",
    "clipboardWrite",
    "storage"
  ],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ]
}